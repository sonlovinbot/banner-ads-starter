# ═══════════════════════════════════════════════════════════════
# AI Banner Pro — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# HƯỚNG DẪN:
#   1. Copy file này thành .env.local
#   2. Bỏ dấu # ở dòng anh muốn bật + điền value
#   3. Restart dev server: Ctrl+C → npm run dev
#
# CHẠY THỬ KHÔNG CẦN GÌ CẢ:
#   npm install && npm run dev
#   → Mở http://localhost:3000
#   → Login demo: admin / pass
#   → Xem UI ngay
#
# ═══════════════════════════════════════════════════════════════


# ─── GEMINI API KEY (bắt buộc nếu muốn gen banner thật) ─────────
# Đăng ký free: https://aistudio.google.com/apikey
# VITE_GEMINI_API_KEY=AIza...


# ─── SUPABASE (optional — để login đa thiết bị + sync cloud) ────
# Không setup → app dùng demo mode (localStorage).
# Setup: https://supabase.com → New project → Settings → API
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGc...


# ─── COACHIO (optional — alternative generation backend) ────────
# Đăng ký: https://coachio.ai
# Không cần nếu đã có Gemini key. Coachio wrap GPT Image 2 + Nano Banana Pro.
# VITE_COACHIO_API_KEY=coa_...


# ─── CDN PROXY (optional — cho ảnh Bunny CDN với CORS handling) ─
# Mặc định dùng https://cdn.coachio.ai (public proxy).
# Anh có thể override nếu deploy Vercel riêng.
# VITE_CDN_PROXY_BASE=https://cdn.coachio.ai
